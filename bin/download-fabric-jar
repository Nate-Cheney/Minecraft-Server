#!/bin/bash
set -e


# Determine the desired Minecraft Version
if [ -z "$MINECRAFT_VERSION" ] || [ "$MINECRAFT_VERSION" = "latest" ]; then
    echo "Getting the latest stable Minecraft version supported by Fabric..."
    MINECRAFT_VERSION=$(curl -s https://meta.fabricmc.net/v2/versions/game | jq -r '[.[] | select(.stable == true)][0].version')
fi

echo "Target Minecraft version: $MINECRAFT_VERSION"

# Get the latest Fabric Loader version for the specified Minecraft version
echo "Getting the latest Fabric Loader version..."
LOADER_VERSION=$(curl -s "https://meta.fabricmc.net/v2/versions/loader/$MINECRAFT_VERSION" | jq -r '.[0].loader.version')

# Ensure the loader version was found
if [ "$LOADER_VERSION" = "null" ] || [ -z "$LOADER_VERSION" ]; then
    echo "Error: Could not find a valid Fabric loader for Minecraft $MINECRAFT_VERSION."
    exit 1
fi

# Get the latest Fabric Installer version
echo "Getting the latest Fabric Installer version..."
INSTALLER_VERSION=$(curl -s https://meta.fabricmc.net/v2/versions/installer | jq -r '.[0].version')

# Ensure the installer version was found
if [ "$INSTALLER_VERSION" = "null" ] || [ -z "$INSTALLER_VERSION" ]; then
    echo "Error: Could not find a valid Fabric installer version."
    exit 1
fi

# Construct the Fabric Meta direct download URL
SERVER_URL="https://meta.fabricmc.net/v2/versions/loader/$MINECRAFT_VERSION/$LOADER_VERSION/$INSTALLER_VERSION/server/jar"

echo "Downloading Fabric server jar for Minecraft $MINECRAFT_VERSION (Loader: $LOADER_VERSION, Installer: $INSTALLER_VERSION)..."
wget -q -O server.jar "$SERVER_URL"

# Ensure jar was downloaded and isn't an empty file
if [ ! -s server.jar ]; then
    echo "The jar file was not downloaded or is empty."
    exit 1
fi

echo "Fabric server jar successfully downloaded."
exit 0

