#!/bin/bash
set -e


PAPER_FILE=server.jar
PAPER_URL=https://fill-data.papermc.io/v1/objects/c140524a3c7c6367de1a68f71d579fc8e3f6186187d56077e719c5eed4ff9be1/paper-26.1.2-19.jar

echo "Downloading the Paper MC server jar..."
wget -q -O $PAPER_FILE $PAPER_URL
if [ ! -f "$PAPER_FILE" ]; then
    echo "Error, the Paper MC jar did not download sucessfully."
    exit 1
fi

exit 0

